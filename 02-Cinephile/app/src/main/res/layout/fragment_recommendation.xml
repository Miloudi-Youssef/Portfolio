<?xml version="1.0" encoding="utf-8"?>
<!-- recommendation screen — genre chip filter row, loading spinner, results grid, refresh FAB -->
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingTop="20dp">

        <!-- Genre chip row -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:paddingTop="4dp"
            android:paddingBottom="8dp"
            android:paddingStart="12dp"
            android:paddingEnd="64dp">

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chip_group_genres"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:singleSelection="true"
                app:selectionRequired="true">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_all"
                    style="@style/CinephileChipStyle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/genre_all"
                    android:checked="true" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_action"
                    style="@style/CinephileChipStyle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/genre_action" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_scifi"
                    style="@style/CinephileChipStyle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/genre_scifi" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_drama"
                    style="@style/CinephileChipStyle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/genre_drama" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_comedy"
                    style="@style/CinephileChipStyle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/genre_comedy" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_thriller"
                    style="@style/CinephileChipStyle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/genre_thriller" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_horror"
                    style="@style/CinephileChipStyle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/genre_horror" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_animation"
                    style="@style/CinephileChipStyle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/genre_animation" />

            </com.google.android.material.chip.ChipGroup>
        </HorizontalScrollView>

        <ProgressBar
            android:id="@+id/progress_bar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tv_empty"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/no_recommendations"
            android:textColor="@color/colorOnBackground"
            android:textSize="14sp"
            android:gravity="center"
            android:padding="32dp"
            android:visibility="gone" />

        <!-- Shown only when displaying trending/popular movies (no personal profile yet) -->
        <TextView
            android:id="@+id/tv_trending_banner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/trending_banner"
            android:textColor="@color/colorSubtext"
            android:textSize="12sp"
            android:gravity="center"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="4dp"
            android:paddingBottom="10dp"
            android:visibility="gone" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_recommendations"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false" />

    </LinearLayout>

    <!-- Floating refresh FAB -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/btn_refresh"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:layout_marginTop="24dp"
        android:layout_marginEnd="12dp"
        android:src="@drawable/ic_refresh"
        android:contentDescription="@string/refresh"
        app:fabSize="mini"
        app:backgroundTint="@color/colorPrimary"
        app:elevation="6dp" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
