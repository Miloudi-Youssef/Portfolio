<?xml version="1.0" encoding="utf-8"?>
<!-- quiz detail screen — quiz metadata, difficulty badge, play button, attempt history list -->
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="32dp">

        <!-- Header section -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="&#127942;"
            android:textSize="64sp"
            android:gravity="center"
            android:layout_marginBottom="20dp" />

        <TextView
            android:id="@+id/tv_quiz_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/colorOnBackground"
            android:textSize="22sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tv_watchlist_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/colorSubtext"
            android:textSize="15sp"
            android:gravity="center"
            android:layout_marginBottom="12dp" />

        <!-- Difficulty badge -->
        <TextView
            android:id="@+id/tv_difficulty"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:paddingHorizontal="16dp"
            android:paddingVertical="5dp"
            android:textSize="13sp"
            android:textStyle="bold"
            android:background="@color/colorSurface2"
            android:layout_marginBottom="28dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_play"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/play_quiz"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:padding="16dp"
            app:backgroundTint="@color/colorPrimary"
            app:cornerRadius="12dp" />

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#333333"
            android:layout_marginTop="28dp"
            android:layout_marginBottom="20dp" />

        <!-- Attempt history section -->
        <TextView
            android:id="@+id/tv_history_header"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/history_header"
            android:textColor="@color/colorOnBackground"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="10dp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tv_no_attempts"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/no_attempts_yet"
            android:textColor="@color/colorSubtext"
            android:textSize="14sp"
            android:gravity="center"
            android:visibility="gone" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_attempts"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false"
            android:visibility="gone" />

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
