<?xml version="1.0" encoding="utf-8"?>
<!-- quiz play screen — progress bar, countdown timer, question, 4 answer buttons, result panel -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="20dp">

    <!-- Progress text -->
    <TextView
        android:id="@+id/tv_question_progress"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="6dp"
        android:gravity="end"
        android:textColor="@color/colorSubtext"
        android:textSize="13sp" />

    <!-- Visual progress bar -->
    <com.google.android.material.progressindicator.LinearProgressIndicator
        android:id="@+id/quiz_progress_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        app:indicatorColor="@color/colorPrimary"
        app:trackColor="@color/colorSurface3"
        app:trackCornerRadius="4dp" />

    <!-- Countdown timer -->
    <TextView
        android:id="@+id/tv_timer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:layout_marginBottom="8dp"
        android:textSize="36sp"
        android:textStyle="bold"
        android:textColor="@color/colorOnBackground"
        android:text="15" />

    <!-- Question -->
    <TextView
        android:id="@+id/tv_question"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        android:gravity="center"
        android:lineSpacingExtra="4dp"
        android:minHeight="80dp"
        android:textColor="@color/colorOnBackground"
        android:textSize="18sp"
        android:textStyle="bold" />

    <!-- Answer buttons -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_answer_1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="10dp"
        android:padding="14dp"
        android:textColor="@color/white"
        app:cornerRadius="12dp"
        app:backgroundTint="@color/colorSurface2" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_answer_2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="10dp"
        android:padding="14dp"
        android:textColor="@color/white"
        app:cornerRadius="12dp"
        app:backgroundTint="@color/colorSurface2" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_answer_3"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="10dp"
        android:padding="14dp"
        android:textColor="@color/white"
        app:cornerRadius="12dp"
        app:backgroundTint="@color/colorSurface2" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_answer_4"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:padding="14dp"
        android:textColor="@color/white"
        app:cornerRadius="12dp"
        app:backgroundTint="@color/colorSurface2" />

    <!-- Next question button — shown after answering -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_next"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        android:text="@string/next_question"
        android:textColor="@color/white"
        android:visibility="gone"
        app:backgroundTint="@color/colorPrimary"
        app:cornerRadius="20dp" />

    <!-- Result panel -->
    <LinearLayout
        android:id="@+id/layout_result"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:gravity="center"
            android:text="@string/quiz_finished"
            android:textColor="@color/colorAccent"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_score"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            android:gravity="center"
            android:textColor="@color/colorOnBackground"
            android:textSize="18sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_back"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/ok"
            android:textColor="@color/white"
            app:backgroundTint="@color/colorPrimary"
            app:cornerRadius="20dp" />

    </LinearLayout>

</LinearLayout>
