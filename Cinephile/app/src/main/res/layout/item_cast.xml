<?xml version="1.0" encoding="utf-8"?>
<!-- cast strip item — circular actor photo, actor name, character name -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="90dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="6dp"
    android:gravity="center">

    <!-- actor photo — 60dp circle via ShapeableImageView; loaded by CastAdapter -->
    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/iv_actor_photo"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:scaleType="centerCrop"
        android:layout_marginBottom="6dp"
        android:background="@color/colorSurface3"
        app:shapeAppearanceOverlay="@style/CircleImageView" />

    <!-- actor name — bold, max 2 lines -->
    <TextView
        android:id="@+id/tv_actor_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/colorOnBackground"
        android:textSize="11sp"
        android:textStyle="bold"
        android:gravity="center"
        android:maxLines="2"
        android:ellipsize="end"
        android:layout_marginBottom="2dp" />

    <!-- character name — italic subtext, max 2 lines -->
    <TextView
        android:id="@+id/tv_character"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/colorSubtext"
        android:textSize="10sp"
        android:gravity="center"
        android:maxLines="2"
        android:ellipsize="end"
        android:fontStyle="italic" />

</LinearLayout>
