<?xml version="1.0" encoding="utf-8"?>
<!--
    navigation graph — single-activity nav component graph.
    Start destination: searchFragment (the search/landing screen).
    Bottom nav tabs: search, watchlist, quiz, recommendation.
    Details fragment is a sub-destination reachable from search, watchlist detail, and recommendation.
    Quiz play fragment is reachable only from quiz detail.
-->
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    app:startDestination="@id/searchFragment">

    <!-- search screen — start destination; navigates to movie details -->
    <fragment
        android:id="@+id/searchFragment"
        android:name="com.cinephile.ui.search.SearchFragment"
        android:label="@string/nav_search">
        <action
            android:id="@+id/action_search_to_details"
            app:destination="@id/detailsFragment" />
    </fragment>

    <!-- movie details — receives movieId int arg; reachable from search, watchlist, recommendations -->
    <fragment
        android:id="@+id/detailsFragment"
        android:name="com.cinephile.ui.details.DetailsFragment"
        android:label="@string/synopsis">
        <argument
            android:name="movieId"
            app:argType="integer" />
    </fragment>

    <!-- watchlist list — navigates to watchlist detail -->
    <fragment
        android:id="@+id/watchlistFragment"
        android:name="com.cinephile.ui.watchlist.WatchlistFragment"
        android:label="@string/nav_watchlists">
        <action
            android:id="@+id/action_watchlist_to_watchlistDetail"
            app:destination="@id/watchlistDetailFragment" />
    </fragment>

    <!-- watchlist detail — receives watchlistId long arg; navigates to movie details -->
    <fragment
        android:id="@+id/watchlistDetailFragment"
        android:name="com.cinephile.ui.watchlistdetail.WatchlistDetailFragment"
        android:label="@string/nav_watchlists">
        <argument
            android:name="watchlistId"
            app:argType="long" />
        <action
            android:id="@+id/action_watchlistDetail_to_details"
            app:destination="@id/detailsFragment" />
    </fragment>

    <!-- quiz list — navigates to quiz detail -->
    <fragment
        android:id="@+id/quizFragment"
        android:name="com.cinephile.ui.quiz.QuizFragment"
        android:label="@string/nav_quiz">
        <action
            android:id="@+id/action_quiz_to_quizDetail"
            app:destination="@id/quizDetailFragment" />
    </fragment>

    <!-- quiz detail — receives quizId long arg; shows metadata, attempt history, play button -->
    <fragment
        android:id="@+id/quizDetailFragment"
        android:name="com.cinephile.ui.quiz.QuizDetailFragment"
        android:label="@string/nav_quiz">
        <argument
            android:name="quizId"
            app:argType="long" />
        <action
            android:id="@+id/action_quizDetail_to_quizPlay"
            app:destination="@id/quizPlayFragment" />
    </fragment>

    <!-- quiz play — receives quizId long arg; active quiz session, forced portrait -->
    <fragment
        android:id="@+id/quizPlayFragment"
        android:name="com.cinephile.ui.quiz.QuizPlayFragment"
        android:label="@string/play_quiz">
        <argument
            android:name="quizId"
            app:argType="long" />
    </fragment>

    <!-- recommendation screen — genre chip filter, navigates to movie details -->
    <fragment
        android:id="@+id/recommendationFragment"
        android:name="com.cinephile.ui.recommendation.RecommendationFragment"
        android:label="@string/nav_recommendations">
        <action
            android:id="@+id/action_recommendation_to_details"
            app:destination="@id/detailsFragment" />
    </fragment>

</navigation>
